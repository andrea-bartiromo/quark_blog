# =================================================================
# Quark — Configurazione PRODUZIONE
# Copiare in .env sul server e compilare i valori reali solo localmente.
# Non versionare mai .env o segreti reali nel repository.
# =================================================================

APP_NAME="Quark"
APP_ENV=production
APP_KEY= # generare con: php artisan key:generate
APP_DEBUG=false # MAI true in produzione
APP_URL=https://www.example.com
APP_LOCALE=it
APP_TIMEZONE=Europe/Rome

# Database
DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite

# Cache & Session (usare redis in produzione se disponibile)
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true # richiede HTTPS
SESSION_SAME_SITE=strict

# Mail / SMTP Gmail
# Usare una Google App Password, non la password dell'account Google.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@example.com
MAIL_FROM_NAME="Quark"

# Claude AI (per automazione notizie)
ANTHROPIC_API_KEY=

# Log
LOG_CHANNEL=daily
LOG_LEVEL=error # non debug in produzione
