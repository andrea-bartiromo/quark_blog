# ════════════════════════════════════════════════════════
# Il Laboratorio — Configurazione PRODUZIONE
# Copiare in .env sul server e compilare i valori
# ════════════════════════════════════════════════════════

APP_NAME="Il Laboratorio"
APP_ENV=production
APP_KEY=           # php artisan key:generate
APP_DEBUG=false    # MAI true in produzione
APP_URL=https://www.illaboratorio.it
APP_LOCALE=it
APP_TIMEZONE=Europe/Rome

# Database
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/illaboratorio/database/database.sqlite

# Cache & Session (usare redis in produzione se disponibile)
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true     # richiede HTTPS
SESSION_SAME_SITE=strict

# Mail (configurare con il provider reale)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=redazione@illaboratorio.it
MAIL_FROM_NAME="Il Laboratorio"

# Claude AI (per automazione notizie)
ANTHROPIC_API_KEY=

# Log
LOG_CHANNEL=daily
LOG_LEVEL=error    # non debug in produzione
